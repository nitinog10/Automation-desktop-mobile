# ===================================
# GitWake Assistant – Environment Variables
# ===================================
# Copy this file to .env and fill in your values.

# --- Porcupine Wake Word (https://picovoice.ai/) ---
PORCUPINE_ACCESS_KEY=your_picovoice_access_key_here

# --- GitHub API ---
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username_here


OPENAI_API_KEY=your_openai_api_key_here

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- ADB Path (if not on PATH) ---
ADB_PATH=adb

# --- Chrome Profile (for WhatsApp/LinkedIn to remember login) ---
CHROME_PROFILE_DIR=C:\Users\DELL\AppData\Local\Google\Chrome\User Data
CHROME_PROFILE_NAME=Default

# --- Whisper (optional offline STT) ---
USE_WHISPER=false
WHISPER_MODEL=base
